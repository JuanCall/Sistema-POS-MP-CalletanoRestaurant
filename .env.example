# ============================================
# 🔐 CONFIGURACIÓN SEGURA — CALLETANO POS
# ============================================
# Copia este archivo como .env y completa tus claves
# ¡NUNCA subas el .env real al repositorio!
#
# 📍 Ubicación del archivo .env:
#   - Desarrollo: raíz del proyecto (junto a package.json)
#   - Producción: carpeta userData de la app Electron
#     (se crea automáticamente al iniciar la app empaquetada)

# 🔑 Google Gemini AI — https://aistudio.google.com/app/apikey
# Necesaria para: análisis táctico diario y estrategia mensual con IA
GEMINI_API_KEY=tu_clave_de_gemini_aqui

# 🔑 ApisPeru SUNAT Token — https://apisperu.com
# Necesaria para: emisión de boletas electrónicas SUNAT
APISPERU_TOKEN=tu_token_de_apisperu_aqui
